# Port for the backend server
PORT=5000

# Secret key for JWT session tokens (choose a secure random string)
JWT_SECRET=your_jwt_secret_key_here

# Firebase configuration (Alternative 1: Env variables)
# Fill these if you want to configure Firebase via environment variables
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase configuration (Alternative 2: Config file)
# Alternatively, leave the above FIREBASE_* variables empty and place your 
# serviceAccountKey.json file directly inside the "backend/config/" directory.

# Firestore settings
ENABLE_FIRESTORE_WARMUP=false
LOGIN_QUOTA_RETRY_SECONDS=60
